# ─── Vercel Postgres (primary storage for Vercel deployments) ────────────────
# These variables are set automatically when you link a Vercel Postgres /
# Neon database to your project via the Vercel dashboard.
# For local development with `vercel dev`, run `vercel env pull .env.local` to
# populate them automatically.
#
# POSTGRES_URL=postgres://<user>:<password>@<host>/<dbname>?sslmode=require
# POSTGRES_URL_NON_POOLING=postgres://<user>:<password>@<host>/<dbname>?sslmode=require
# POSTGRES_USER=<user>
# POSTGRES_HOST=<host>
# POSTGRES_PASSWORD=<password>
# POSTGRES_DATABASE=<dbname>

# ─── Legacy FastAPI + MongoDB (optional, retained for reference) ──────────────
# Only needed if you run the local FastAPI backend instead of `vercel dev`.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=career_assessment
MONGODB_COLLECTION=assessments

# ─── Frontend API base URL (optional override) ───────────────────────────────
# Leave empty when deploying to Vercel — the frontend and API share the same
# origin.  Set this only when the frontend is served from a different host,
# e.g. when running the legacy FastAPI backend locally:
#   VITE_API_BASE_URL=http://localhost:3001/api
# VITE_API_BASE_URL=
