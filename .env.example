# ─── Vercel Postgres (primary storage for Vercel deployments) ────────────────
# These variables are set automatically when you link a Vercel Postgres /
# Neon database to your project via the Vercel dashboard.
# For local development with `vercel dev`, run `vercel env pull .env.local` to
# populate them automatically.
#
# POSTGRES_URL=postgres://<user>:<password>@<host>/<dbname>?sslmode=require
# POSTGRES_URL_NON_POOLING=postgres://<user>:<password>@<host>/<dbname>?sslmode=require
# POSTGRES_USER=<user>
# POSTGRES_HOST=<host>
# POSTGRES_PASSWORD=<password>
# POSTGRES_DATABASE=<dbname>

# ─── Google Sheets storage (alternative / supplemental persistence) ───────────
# Set GOOGLE_SHEETS_WEBHOOK_URL to the "Web App" URL produced when you deploy
# apps-script/Code.gs via Extensions → Apps Script → Deploy → New deployment.
# If both Postgres and Google Sheets are configured, responses are stored in
# both backends; the request succeeds if at least one backend accepts the data.
#
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/<deployment-id>/exec
#
# Optional shared secret — set the same value as the Apps Script Script Property
# named SHARED_SECRET to add lightweight protection to the webhook endpoint.
# GOOGLE_SHEETS_SECRET=<random-string>

# ─── Frontend API base URL (optional override) ───────────────────────────────
# Leave empty when deploying to Vercel — the frontend and API share the same
# origin.
# VITE_API_BASE_URL=
