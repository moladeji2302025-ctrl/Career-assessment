# MongoDB connection settings for the FastAPI backend.
# Copy this file to .env and adjust the values for your environment.

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=career_assessment
MONGODB_COLLECTION=assessments

# Frontend API base URL (optional).
# Use this when the frontend is served separately from the FastAPI backend.
# Example: VITE_API_BASE_URL=http://localhost:3001/api
# VITE_API_BASE_URL=
